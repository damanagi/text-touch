{
  "name": "text-touch",
  "version": "0.6.0",
  "description": "로컬 HTML 파일의 텍스트만 인라인으로 편집하는 데스크탑 앱 (macOS / Windows)",
  "main": "src/main.js",
  "author": "Kay",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --mac --arm64",
    "build:dir": "electron-builder --mac --arm64 --dir",
    "build:win": "electron-builder --win --x64",
    "build:all": "electron-builder --mac --arm64 --win --x64"
  },
  "devDependencies": {
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "kr.kay.texttouch",
    "productName": "Text Touch",
    "files": [
      "src/**/*",
      "assets/icon.icns",
      "assets/icon.ico",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Text Touch ${version}",
      "icon": "assets/icon.icns",
      "background": null,
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 130,
          "y": 200,
          "type": "file"
        },
        {
          "x": 410,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "writeUpdateInfo": false
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-win-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Text Touch",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "fileAssociations": [
      {
        "ext": "html",
        "name": "HTML Document",
        "role": "Editor"
      },
      {
        "ext": "htm",
        "name": "HTML Document",
        "role": "Editor"
      }
    ]
  },
  "dependencies": {
    "iconv-lite": "^0.7.2"
  }
}
